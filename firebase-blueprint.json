{
  "entities": {
    "inventory": {
      "title": "Inventory",
      "description": "Inventory data for a specific SKU",
      "type": "object",
      "properties": {
        "sku": { "type": "string" },
        "productName": { "type": "string" },
        "currentStock": { "type": "number" },
        "targetStock": { "type": "number" },
        "expectedSales": { "type": "number" },
        "unitCost": { "type": "number" },
        "allocatedBudget": { "type": "number" },
        "leadTime": { "type": "number" },
        "seasonMultiplier": { "type": "number" },
        "safetyBuffer": { "type": "number" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["sku", "currentStock", "targetStock"]
    },
    "activity": {
      "title": "Activity",
      "description": "Recent inventory activities",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["shipment", "order", "alert"] },
        "description": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "units": { "type": "number" },
        "status": { "type": "string" }
      },
      "required": ["type", "description", "timestamp"]
    },
    "chatHistory": {
      "title": "Chat History",
      "description": "User chat history with Gemini",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "messages": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "role": { "type": "string", "enum": ["user", "model"] },
              "text": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" }
            }
          }
        }
      }
    }
  },
  "firestore": {
    "/inventory/{sku}": {
      "schema": "inventory",
      "description": "Main inventory data"
    },
    "/activities": {
      "schema": "activity",
      "description": "Recent activity log"
    },
    "/chats/{userId}": {
      "schema": "chatHistory",
      "description": "User chat history"
    }
  }
}
